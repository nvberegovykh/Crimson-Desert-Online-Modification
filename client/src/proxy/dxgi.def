; SPDX-License-Identifier: MIT
; Export the dxgi entry points the OS / game looks up, mapping each to our
; Proxy_* implementation which forwards to the genuine System32\dxgi.dll.
LIBRARY dxgi
EXPORTS
    CreateDXGIFactory = Proxy_CreateDXGIFactory
    CreateDXGIFactory1 = Proxy_CreateDXGIFactory1
    CreateDXGIFactory2 = Proxy_CreateDXGIFactory2
    DXGIGetDebugInterface1 = Proxy_DXGIGetDebugInterface1
    DXGID3D10CreateDevice = Proxy_DXGID3D10CreateDevice
    DXGIDeclareAdapterRemovalSupport = Proxy_DXGIDeclareAdapterRemovalSupport
